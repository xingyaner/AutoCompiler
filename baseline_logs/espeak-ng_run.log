# build project
export ASAN_OPTIONS=detect_leaks=0
./autogen.sh

# Configure without --with-libfuzzer to avoid linking issues
# The fuzzer tests will be built separately with $LIB_FUZZING_ENGINE
./configure --disable-shared --with-speechplayer=no

