################################################################################


# build project
export ASAN_OPTIONS=detect_leaks=0
./autogen.sh

# Don't use libfuzzer when building with AFL
if [[ "$FUZZING_ENGINE" == "afl" ]]; then
    ./configure --with-libfuzzer=no --disable-shared --with-speechplayer=no
else
    ./configure --with-libfuzzer=yes --disable-shared --with-speechplayer=no
fi

make check || true
cp tests/ssml-fuzzer.test $OUT/ssml-fuzzer
cp -r espeak-ng-data/ $OUT/
EOF
